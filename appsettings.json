{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=Localhost,1433;Database=ApexDbContext;User Id=SA;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY_MIN_32_CHARACTERS_LONG",
    "Issuer": "api.apexec.az",
    "Audience": "admin.apexec.az",
    "ExpireMinutes": 480
  },
  "App": {
    "BaseUrl": "https://api.apexec.az"
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "YOUR_SENDER_EMAIL",
    "SenderPassword": "YOUR_GMAIL_APP_PASSWORD",
    "ReceiverEmail": "YOUR_RECEIVER_EMAIL"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
